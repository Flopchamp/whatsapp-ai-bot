# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
# The verify token you set when configuring the webhook in Meta dashboard
VERIFY_TOKEN=your_verify_token_here

# Your WhatsApp Business phone number ID (found in Meta developer dashboard)
WHATSAPP_PHONE_ID=your_phone_id_here

# Permanent or temporary access token from Meta
WHATSAPP_TOKEN=your_whatsapp_token_here

# WhatsApp Cloud API version (default: v21.0)
WHATSAPP_API_VERSION=v21.0

# App secret from Meta dashboard (used to verify webhook signatures)
APP_SECRET=your_app_secret_here

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
